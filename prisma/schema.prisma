// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Url {
  id        BigInt    @id
  shortCode String    @unique
  longUrl   String    @unique
  clicks    Int       @default(0)
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  userID    String?

  clicksData Click[] // Relation back to the Click model
  stats      UrlStats? // 1-to-1 relation to the materialized stats
}

model Click {
  id        BigInt   @id @default(autoincrement())
  urlId     BigInt
  createdAt DateTime @default(now())
  ip        String?
  userAgent String?
  country   String?

  // Defines the Foreign Key relation (a Click belongs to a Url)
  url       Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)

  // Creates an index on urlId to make count/fetch queries super fast
  @@index([urlId])
}

model UrlStats {
  urlId          BigInt   @id
  totalClicks    Int      @default(0)
  uniqueVisitors Int      @default(0)
  lastUpdated    DateTime @updatedAt
  // 1-to-1 Relation back to the Url model
  url            Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)
}